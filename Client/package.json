{
	"name": "client",
	"type": "module",
	"scripts": {
		"envDev": "bun run _genClientEnv.ts",
		"envProd": "cross-env B_PROD=true bun run _genClientEnv.ts",
		"dev": "bunx --bun vite",
		"watch": "bun run envDev && nodemon -w src -e css,ts,tsx --exec bun run _build.ts",
		"buildDev": "bun run envDev && bun run _build.ts",
		"buildProd": "bun run envProd && bun run _build.ts",
		"build": "bun run buildDev",
		"preview": "serve -l 4173 ./dist",
		"deploy": "bun run _deploy.ts",
		"buildDeploy": "bun run buildProd && bun run deploy",
		"devhost": "bunx --bun vite --host",
		"devhttps": "cross-env USE_HTTPS=true npx vite",
		"devhttpshost": "cross-env USE_HTTPS=true npx vite --host",
		"_build": "vite build # bun run build is preferred",
		"_preview": "vite preview",
		"doc": "typedoc && cmd /c \"start typedoc_out/index.html\"",
		"test": "bunx playwright test",
		"cov": "cross-env USE_COVERAGE=true bunx playwright test && cmd /c \"start coverage-reports/index.html\"",
		"testui": "bunx playwright test --ui",
		"testdebug": "bunx playwright test --debug",
		"testhtml": "cross-env USE_HTML=true bunx playwright test",
		"testcsr": "cross-env USE_CSR=true bunx playwright test",
		"codegen": "bunx playwright codegen",
		"lint": "eslint --ext .ts,tsx --ignore-path .gitignore .",
		"lintfix": "eslint --ext .ts,tsx --ignore-path .gitignore --fix ."
	},
	"devDependencies": {
		"@playwright/test": "1.48.2",
		"@types/bun": "1.1.13",
		"@types/dom-view-transitions": "1.0.5",
		"@types/node": "22.9.0",
		"@types/react": "18.3.12",
		"@types/react-dom": "18.3.1",
		"@typescript-eslint/eslint-plugin": "8.13.0",
		"@vitejs/plugin-react": "4.3.3",
		"@zamiell/typedoc-plugin-not-exported": "0.3.0",
		"cross-env": "7.0.3",
		"eslint": "8.57.0",
		"eslint-plugin-react": "7.37.2",
		"eslint-plugin-react-hooks": "5.0.0",
		"jest": "29.7.0",
		"monocart-coverage-reports": "2.11.2",
		"monocart-reporter": "2.9.9",
		"tslib": "2.8.1",
		"vite-plugin-mkcert": "1.17.6"
	},
	"dependencies": {
		"@preact/signals": "1.3.0",
		"clsx": "2.1.1",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"vite-plugin-watch": "vite-plugin-watch-0.4.0.tgz"
	}
}
